{
  "name": "deploykit",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@babel/core": "^7.29.0",
      "@eslint/js": "^10.0.1",
      "@rolldown/plugin-babel": "^0.2.3",
      "@tailwindcss/vite": "^4.2.4",
      "@types/babel__core": "^7.20.5",
      "@types/node": "^24.12.2",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "@vitejs/plugin-react": "^6.0.1",
      "babel-plugin-react-compiler": "^1.0.0",
      "bun-types": "^1.3.13",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "eslint": "^10.2.1",
      "eslint-plugin-react-hooks": "^7.1.1",
      "eslint-plugin-react-refresh": "^0.5.2",
      "globals": "^17.5.0",
      "hono": "^4.12.15",
      "i18next": "^26.0.8",
      "i18next-browser-languagedetector": "^8.2.1",
      "lucide-react": "^1.14.0",
      "radix-ui": "^1.4.3",
      "react": "^19.2.5",
      "react-dom": "^19.2.5",
      "react-i18next": "^17.0.6",
      "react-router": "^7.14.2",
      "shadcn": "^4.6.0",
      "tailwind-merge": "^3.5.0",
      "tailwindcss": "^4.2.4",
      "tw-animate-css": "^1.4.0",
      "typescript": "~6.0.2",
      "typescript-eslint": "^8.58.2",
      "vite": "^8.0.10"
    }
  },
  "scripts": {
    "dev": "bun --filter @deploykit/server dev",
    "dev:web": "bun --filter @deploykit/web dev",
    "dev:server": "bun --filter @deploykit/server dev",
    "build": "bun --filter '*' build",
    "test": "bun --filter '*' test",
    "lint": "bun --filter @deploykit/web lint",
    "typecheck": "bun --filter '*' typecheck"
  }
}
