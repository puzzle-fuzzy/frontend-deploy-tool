{
  "name": "deploykit",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@biomejs/biome": "^2.5.1",
      "@babel/core": "^7.29.0",
      "@rolldown/plugin-babel": "^0.2.3",
      "@tailwindcss/vite": "^4.2.4",
      "@types/babel__core": "^7.20.5",
      "@types/node": "^24.12.2",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "@vitejs/plugin-react": "^6.0.1",
      "babel-plugin-react-compiler": "^1.0.0",
      "bun-types": "^1.3.13",
      "cheerio": "^1.2.0",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "fflate": "^0.8.2",
      "globals": "^17.5.0",
      "hono": "^4.12.15",
      "i18next": "^26.0.8",
      "i18next-browser-languagedetector": "^8.2.1",
      "lucide-react": "^1.14.0",
      "nanoid": "^5.1.16",
      "radix-ui": "^1.4.3",
      "react": "^19.2.5",
      "react-dom": "^19.2.5",
      "react-i18next": "^17.0.6",
      "react-router": "^7.14.2",
      "shadcn": "^4.6.0",
      "tailwind-merge": "^3.5.0",
      "tailwindcss": "^4.2.4",
      "turbo": "^2.10.2",
      "tw-animate-css": "^1.4.0",
      "typescript": "~6.0.2",
      "vite": "^8.0.10",
      "zod": "^4.4.3"
    }
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "bun --filter @deploykit/web dev",
    "dev:server": "bun --filter @deploykit/server dev",
    "build": "turbo run build && bun run package",
    "package": "bun run scripts/package-web.ts",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "bun biome format --write .",
    "format:check": "bun biome format .",
    "check": "bun biome check .",
    "check:fix": "bun biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "turbo": "catalog:"
  }
}
