# Server Environment Variables

# Server configuration
# Server port (default: 3000)
PORT=3000

# Storage configuration
# Path to metadata file (relative to server dir or absolute)
DATA_FILE=data.json
# Path to deployment storage directory (relative to server dir or absolute)
STORAGE_DIR=.voasx/storage
# Path to management UI static files (relative to server dir or absolute)
PUBLIC_DIR=public

# Deployment URLs
# Base URL for deployment links (e.g., https://deploy.example.com)
# Leave unset to use the same origin as the server
PUBLIC_BASE_URL=

# Upload limits (in bytes/characters, use defaults if not set)
# Maximum ZIP file size (default: 104857600 = 100MB)
MAX_ZIP_SIZE=104857600
# Maximum extracted size (default: 104857600 = 100MB)
MAX_EXTRACTED_SIZE=104857600
# Maximum number of files (default: 1000)
MAX_FILE_COUNT=1000
# Maximum path length (default: 1000 characters)
MAX_PATH_LENGTH=1000
